      <!-- Popular support threshold below which garrison troops are required -->
      <SupportThreshold>60</SupportThreshold>
      <!-- Divisor for garrison calculation: ceil((threshold - support) / divisor) -->
      <GarrisonDivisor>10</GarrisonDivisor>
      <!-- Multiplier applied to garrison requirement during an uprising -->
      <UprisingMultiplier>2</UprisingMultiplier>
    </Garrison>

    <!-- Fleet deployment probability gate bounds (PARAM_1538, PARAM_1539) -->
    <!-- AI rolls random(low, high); deploys only if roll < net_strength_ratio -->
    <DeploymentGateLow>20</DeploymentGateLow>
    <DeploymentGateHigh>80</DeploymentGateHigh>

    <!-- Capital ship production pipeline parameters -->
    <CapitalShipProduction>
      <!-- Personnel divisor for facility contribution: (skill / divisor + 1) * modifier -->
      <!-- GNPR param 1537, same value as Combat.AssaultPersonnelDivisor -->
      <FacilityPersonnelDivisor>40</FacilityPersonnelDivisor>
      <!-- Strike target evaluation thresholds -->
      <StrikeThresholdLow>1</StrikeThresholdLow>
      <StrikeThresholdHigh>10</StrikeThresholdHigh>
      <!-- Energy resistance values for strike evaluation -->
      <EnergyStrikeResistance>9</EnergyStrikeResistance>
      <AllocatedEnergyStrikeResistance>9</AllocatedEnergyStrikeResistance>
      <!-- Support shift applied to PRODUCING faction's own support (Death Star only) -->
      <!-- FUN_00558860 returns GENERAL_PARAM_7705 = -20 (negative = military disruption) -->
      <OrbitalStrikeSupportShift>-20</OrbitalStrikeSupportShift>
    </CapitalShipProduction>

  <!-- System Resources: dice formulas from original disassembly.
       Core energy: roll(4) + 10, clamp(0,15)
       Rim energy: roll(9) + roll(4) + 1, clamp(0,15)
       Core raw: roll(9) + 5, clamp(0,15), then clamp to energy
       Rim raw: roll(14) + 1, clamp(0,15), then clamp to energy
       Rim colonization: GENERAL_PARAM_7731 = 31 -->
  <SystemResources>
    <CoreEnergy>
      <Base>10</Base>
      <Random1>4</Random1>
      <Random2>0</Random2>
    </CoreEnergy>
    <RimEnergy>
      <Base>1</Base>
      <Random1>9</Random1>
      <Random2>4</Random2>
    </RimEnergy>
    <CoreRawMaterials>
      <Base>5</Base>
      <Random1>9</Random1>
      <Random2>0</Random2>
    </CoreRawMaterials>
    <RimRawMaterials>
      <Base>1</Base>
      <Random1>14</Random1>
      <Random2>0</Random2>
    </RimRawMaterials>
    <EnergyMin>0</EnergyMin>
    <EnergyMax>15</EnergyMax>
    <RawMaterialsMin>0</RawMaterialsMin>
    <RawMaterialsMax>15</RawMaterialsMax>
    <RimColonizationPct>31</RimColonizationPct>
  </SystemResources>
  <!-- System Support: formulas from original disassembly.
       StrongAlliance: roll(random) + base (SIDE_PARAM_CAT15_7682/7683_ALLIANCE)
       StrongEmpire: 100 - (roll(random) + base) (SIDE_PARAM_CAT15_7682/7683_EMPIRE) — inverted
       WeakAlliance: roll(random) + base (SIDE_PARAM_CAT15_7684/7685_ALLIANCE)
       WeakEmpire: 100 - (roll(random) + base) (SIDE_PARAM_CAT15_7684/7685_EMPIRE) — inverted
       Neutral: roll(base) + (50 - base/2) where base = GENERAL_PARAM_7764
       Confirmed values from SDPRTB params 7682-7685 and GNPRTB param 7764:
       Strong Alliance = 60 + roll(30) => 60-90  (SDPRTB 7682/7683)
       Weak Alliance = 20 + roll(30) => 20-50    (SDPRTB 7684/7685)
       Strong Empire = 100 - (60 + roll(30)) = 10-40
       Weak Empire = 100 - (20 + roll(30)) = 50-80
       Neutral = roll(18) + 41 => 41-59           (GNPRTB 7764=18) -->
  <!-- System Support: formulas per bucket strength.
       Strong: support for the owning faction = base + roll(random) = 60-90
       Weak: support for the owning faction = base + roll(random) = 20-50
       Neutral: support for first faction = base + roll(random) = 41-59
       Remainder is distributed evenly among other factions.
       Original values from SDPRTB params 7682-7685 and GNPRTB param 7764. -->
  <SystemSupport>
    <Strong>
      <Base>60</Base>
      <Random>30</Random>
    </Strong>
    <Weak>
      <Base>20</Base>
      <Random>30</Random>
    </Weak>
    <Neutral>
      <Base>41</Base>
      <Random>18</Random>
    </Neutral>
    <RimSupportRandom>0</RimSupportRandom>
  </SystemSupport>

<Project Sdk="Microsoft.NET.Sdk">
  <!--
    Portable project file for Roslynator static analysis in CI.
    Does not depend on Unity-generated files or Unity being installed.
    Excludes the small set of files that directly reference Unity runtime types.
    Unity tests in the CI pipeline prove compilation; this file is for lint only.
  -->
  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <AssemblyName>GameAssembly</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Nullable>disable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <EnableDefaultItems>false</EnableDefaultItems>
    <UnityVersion>6000.4.0f1</UnityVersion>
    <!-- CS8019: unnecessary using directive (stray Unity/Drawing usings in game files) -->
    <NoWarn>0169;0649;1701;1702;8019;1591</NoWarn>
    <!-- CS1573: param tag has no matching parameter; CS1587: comment not on valid element -->
    <WarningsAsErrors>CS1573;CS1587</WarningsAsErrors>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Unity3D" Version="3.1.1" />
  </ItemGroup>
  <ItemGroup>
    <!-- Unity package assemblies not included in the Unity3D NuGet (package-level, not built-in modules) -->
    <Reference Include="UnityEngine.UI">
      <HintPath>Library/ScriptAssemblies/UnityEngine.UI.dll</HintPath>
    </Reference>
    <Reference Include="Unity.TextMeshPro">
      <HintPath>Library/ScriptAssemblies/Unity.TextMeshPro.dll</HintPath>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <!--
      Include all game source files. Exclude only the UI layer — RCS1213 is already
      suppressed there via .editorconfig, and UI MonoBehaviours have nothing to lint.
    -->
    <Compile Include="Assets/Scripts/**/*.cs" />
  </ItemGroup>
</Project>

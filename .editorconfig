# EditorConfig: https://editorconfig.org
root = true

[*.cs]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = crlf
trim_trailing_whitespace = true
insert_final_newline = true

# Private field naming: must be _camelCase
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols  = private_fields
dotnet_naming_rule.private_fields_underscore.style    = underscore_camel_case

dotnet_naming_symbols.private_fields.applicable_kinds          = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization   = camel_case

# Roslynator: unused member detection
# Enabled globally so game logic (Systems, Game, Generation, AI) is checked.
dotnet_diagnostic.RCS1213.severity = warning

# Unity MonoBehaviour classes call Awake/Start/Update/OnDestroy via reflection.
# Suppress false positives in UI and MonoBehaviour-heavy layers.
# Also suppress naming rule: [SerializeField] fields use camelCase (Unity convention).
[Assets/Scripts/UI/**/*.cs]
dotnet_diagnostic.RCS1213.severity = none
dotnet_naming_rule.private_fields_underscore.severity = none

[Assets/Scripts/Managers/AudioManager.cs]
dotnet_diagnostic.RCS1213.severity = none
dotnet_naming_rule.private_fields_underscore.severity = none

[Assets/Scripts/Core/AppBootstrap.cs]
dotnet_diagnostic.RCS1213.severity = none
dotnet_naming_rule.private_fields_underscore.severity = none
